# ---- Discord ----------------------------------------------------------------
DISCORD_TOKEN=
DISCORD_APP_ID=1497214953982005259
DISCORD_PUBLIC_KEY=41b71b0dd559f2a1e56211d89f1831064c708f74b1a92d7bcdfa38f123673711
